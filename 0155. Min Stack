class MinStack {
public:
    MinStack() {}
    stack<long long>st;
    long long mini;
    void push(int value) {
        if(st.empty()){
            mini=value;
            st.push(value);
        }
        else {
            if(value>mini) st.push(value);
            else {
                st.push(2LL*value-mini);
                mini=value;
            }
        }
    }
    
    void pop() {
        long long x=st.top();
        st.pop();
        if(x<mini) mini=2*mini-x;
    }
    
    int top() {
        long long x=st.top();
        if(mini<x)return (int)x;
        return (int)mini;
    }
    
    int getMin() {
        return (int)mini;
    }
};

